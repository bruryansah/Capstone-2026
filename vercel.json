{
  "version": 2,
  "framework": null,

  "buildCommand": "npm run build",
  "outputDirectory": "public/build",

  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },

  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],

  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_URL": "https://capstone-n3f9qi77f-bruryansahs-projects.vercel.app",

    "APP_CONFIG_CACHE": "/tmp/config.php",
    "APP_EVENTS_CACHE": "/tmp/events.php",
    "APP_PACKAGES_CACHE": "/tmp/packages.php",
    "APP_ROUTES_CACHE": "/tmp/routes.php",
    "APP_SERVICES_CACHE": "/tmp/services.php",
    "VIEW_COMPILED_PATH": "/tmp",

    "CACHE_DRIVER": "array",
    "LOG_CHANNEL": "stderr",
    "SESSION_DRIVER": "cookie",

    "DB_CONNECTION": "mysql",
    "DB_HOST": "ISI_DARI_TIDB",
    "DB_PORT": "4000",
    "DB_DATABASE": "ISI_DATABASE",
    "DB_USERNAME": "ISI_USERNAME",
    "DB_PASSWORD": "ISI_PASSWORD",
    "DB_SSLMODE": "require"
  }
}